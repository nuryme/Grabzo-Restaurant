# Copy to .env and fill in. Never commit .env.
PORT=4000
# Local dev: http://localhost:5173 — Production (Render): your Vercel URL, e.g. https://grabzo.vercel.app
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/grabzo
JWT_SECRET=change-me-to-a-long-random-string

# Cloudinary (menu image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# First owner account, created by `npm run seed`
SEED_OWNER_EMAIL=owner@grabzo.test
SEED_OWNER_PASSWORD=grabzo123
